  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(requests_counter_total{service=\"token-shield\"})",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Tokens Processed",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(tokens_counter_total{service=\"token-shield\"})",
          "legendFormat": "tokens"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Errors",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(errors_counter_total{service=\"token-shield\"})",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Average Latency (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(latency_histogram_sum{service=\"token-shield\"}[5m])) / sum(rate(latency_histogram_count{service=\"token-shield\"}[5m]))",
          "legendFormat": "avg latency"
        }
      ]
    },
    {
      "id": 5,
      "title": "P95 Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(latency_histogram_bucket{service=\"token-shield\"}[5m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    }
  ],
